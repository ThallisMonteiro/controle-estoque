generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Categoria {
  id        Int      @id @default(autoincrement())
  nome      String   @unique @db.VarChar(100)
  descricao String?  @db.Text
  criado_em DateTime @default(now())
}

